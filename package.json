{
  "name": "cafe-canva",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform for the Indian restaurant industry",
  "workspaces": [
    "frontend",
    "desktop"
  ],
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "test": "npm run test --prefix frontend",
    "type-check": "npm run type-check --prefix frontend",
    "desktop": "npm run start --prefix desktop",
    "desktop:build": "npm run build --prefix desktop",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yashzagde/Cafe-Canvas.git"
  },
  "keywords": [
    "saas",
    "restaurant",
    "pos",
    "nextjs",
    "supabase",
    "drizzle"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.197",
    "dotenv": "^17.4.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
