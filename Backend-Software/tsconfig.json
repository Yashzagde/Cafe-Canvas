{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "../",
    "resolveJsonModule": true
  },
  "include": ["**/*"],
  "exclude": [
    "**/frontend/**/*",
    "**/store-front/**/*",
    "**/node_modules/**/*",
    "**/.next/**/*",
    "dist/**/*"
  ]
}
