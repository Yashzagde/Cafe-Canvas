## FORBIDDEN PATTERNS

```typescript
// ❌ Direct postgres
import postgres from 'postgres'

// ❌ Express
import express from 'express'

// ❌ Service role key on client
const supabase = createClient(url, SERVICE_ROLE_KEY) // in browser!

// ❌ any types
const data: any = ...

// ❌ Inline styles
style={{ color: 'red', padding: '10px' }}

// ❌ Relative imports
import { foo } from '../../utils/bar'

// ❌ user_metadata for auth decisions
auth.jwt() -> 'user_metadata' ->> 'role'

// ❌ Client-side generated primary key IDs (UUIDs)
const tenantId = crypto.randomUUID()
await supabase.from('tenants').insert({ id: tenantId, ... }) // Let Supabase auto-generate via DEFAULT gen_random_uuid()!
```
