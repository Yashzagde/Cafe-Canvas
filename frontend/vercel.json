{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "regions": ["bom1"],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co; media-src 'self' https://assets.mixkit.co;"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/api/payment/:path*",
      "destination": "/api/payment/:path*"
    },
    {
      "source": "/demo/:path*",
      "destination": "/demo/:path*"
    }
  ],

  "redirects": [
    {
      "source": "/login",
      "has": [{ "type": "cookie", "key": "sb-access-token" }],
      "destination": "/dashboard",
      "permanent": false
    }
  ],

  "crons": [
    {
      "path": "/api/cron/cleanup-expired-sessions",
      "schedule": "0 2 * * *"
    }
  ]
}
